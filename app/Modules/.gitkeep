# Modules Directory
# Place your modules here. Each module should have its own subdirectory.
# Example structure:
#
# app/Modules/Reviews/
# ├── module.json
# ├── ModuleServiceProvider.php
# ├── Controllers/
# ├── Models/
# ├── Services/
# ├── Database/Migrations/
# ├── Routes/
# ├── Events/
# ├── Listeners/
# └── Hooks/
