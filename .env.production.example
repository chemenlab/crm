# Production Environment Configuration for mclient.pro
# Скопируйте эти переменные в Dokploy при создании приложения

# Application
APP_NAME=MasterClient
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_IN_DOKPLOY
APP_DEBUG=false
APP_URL=https://mclient.pro

# Localization
APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

# Logging
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database (MySQL - Dokploy автоматически создаст)
DB_CONNECTION=mysql
DB_HOST=mclient-mysql
DB_PORT=3306
DB_DATABASE=mclient_crm
DB_USERNAME=mclient_user
DB_PASSWORD=WILL_BE_SET_BY_DOKPLOY

# Session & Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.mclient.pro

# Queue & Cache
CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Redis (опционально, если Dokploy предоставит)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (настройте SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@mclient.pro
MAIL_FROM_NAME="${APP_NAME}"

# OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

YANDEX_CLIENT_ID=your-yandex-client-id
YANDEX_CLIENT_SECRET=your-yandex-client-secret
YANDEX_REDIRECT_URI="${APP_URL}/auth/yandex/callback"

# VK Integration
VK_GROUP_ID=your-vk-group-id
VK_ACCESS_TOKEN=your-vk-token
VK_SECRET_KEY=your-vk-secret
VK_CONFIRMATION_CODE=your-vk-confirmation

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL="${APP_URL}/webhooks/telegram"

# SMS Provider
SMS_PROVIDER=smsru
SMSRU_API_ID=your-smsru-api-id

# YooKassa Payment
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_WEBHOOK_SECRET=your-webhook-secret
YOOKASSA_RETURN_URL="${APP_URL}/subscriptions/payment/success"

# Admin Panel Configuration (используйте непредсказуемый путь)
ADMIN_PANEL_PATH=control-panel-x7k9m2

# Vite
VITE_APP_NAME="${APP_NAME}"
